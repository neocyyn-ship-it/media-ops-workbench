# Local development
# You can usually leave this unset because the app defaults to ./data/workbench.db
MEDIA_OPS_DB_PATH=./data/workbench.db

# Vercel demo deployment
# Use /tmp on Vercel because the project directory is read-only at runtime.
# Warning: /tmp is ephemeral, so data will not persist reliably across deployments/restarts.
# MEDIA_OPS_DB_PATH=/tmp/media-ops-workbench.db

# OpenAI assistant
# Server-side only. Never expose this key in the browser.
OPENAI_API_KEY=

# Optional: if you use a third-party OpenAI-compatible provider,
# set its API base URL here, for example https://your-provider.example/v1
OPENAI_BASE_URL=

# Recommended default for this MVP assistant.
# The app uses the official Responses API and defaults to gpt-5-mini if this is unset.
OPENAI_MODEL=gpt-5-mini

# Shared site password. Defaults to 123 in code if this is left empty.
SITE_PASSWORD=123
